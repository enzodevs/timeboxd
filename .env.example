# --- timeboxd configuration ---

# Local SQLite database (libSQL). Defaults to ./data/timeboxd.db if unset.
# For a remote Turso DB use: libsql://your-db.turso.io  (+ DATABASE_AUTH_TOKEN)
DATABASE_URL=file:./data/timeboxd.db
# DATABASE_AUTH_TOKEN=

# Base URL of the running app (used to build the Google OAuth redirect URI).
APP_URL=http://localhost:3000

# --- Google integration (optional) ---
# Create an OAuth 2.0 Client ID (type "Web application") at
# https://console.cloud.google.com/apis/credentials
# Enable the "Google Calendar API" and "Google Tasks API".
# Add this Authorized redirect URI:  ${APP_URL}/api/auth/google/callback
# While the app is in "Testing", add your Google account as a Test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
