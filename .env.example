# --- timeboxd configuration ---

# Local SQLite database (libSQL). Defaults to ./data/timeboxd.db if unset.
# For a remote Turso DB use: libsql://your-db.turso.io  (+ DATABASE_AUTH_TOKEN)
DATABASE_URL=file:./data/timeboxd.db
# DATABASE_AUTH_TOKEN=

# Base URL of the running app (used by auth and Google OAuth redirect URIs).
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret

# Self-hosted installs bypass subscription gating.
SELF_HOSTED=true

# --- Google (sign-in + Calendar/Tasks integration) ---
# Create an OAuth 2.0 Client ID (type "Web application") at
# https://console.cloud.google.com/apis/credentials
# Enable the "Google Calendar API" and "Google Tasks API".
# Add BOTH Authorized redirect URIs (sign-in and the Calendar/Tasks connect flow):
#   ${APP_URL}/api/auth/callback/google     <- Google sign-in (better-auth)
#   ${APP_URL}/api/auth/google/callback     <- Calendar/Tasks connect
# While the app is in "Testing", add your Google account as a Test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (magic-link sign-in) ---
# Without RESEND_API_KEY, magic links are logged to the server console instead of
# emailed (fine for local dev). Get a key at https://resend.com (free tier).
# EMAIL_FROM must use a Resend-verified domain; until you verify one, the shared
# "onboarding@resend.dev" sender only delivers to your own Resend account email.
RESEND_API_KEY=
EMAIL_FROM=timeboxd <onboarding@resend.dev>
